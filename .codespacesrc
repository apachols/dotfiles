export BRANCH_COLOR='36m'

alias grep="grep --color=auto"

export GEMFURY_API_TOKEN="GsM1tgeGkNyFHkFYd5qc"
export GEMFURY_READ_URL="https://repo.fury.io/${GEMFURY_API_TOKEN}/roverdotcom/"

cd /workspaces/web

echo -e "CODESPACESRC\n"

source profile

source /workspaces/web/venv/bin/activate

source /workspaces/web/profile

source /workspaces/web/profile-codespaces

alias claude="~/.local/bin/claude"

alias sp='m shell_plus'

alias web="cd $WEB"

alias pruned='docker system prune -f'

alias lt='dc logs --tail 456'

alias elastichead='docker run -p 9100:9100 mobz/elasticsearch-head:5'

export PRE_COMMMIT_ENABLED=1

export ROVER_FUN_STATUSLINE=1

export ANTHROPIC_AUTH_TOKEN="sk-MSC5sLKQeQlfAHEKZ5O-Dw"

function dcps {
    dc ps  --format='table {{ .Name }}\t{{ .Status }}'
}

function personalize {
    local skills_dir="/workspaces/web/.claude/skills"
    local dotfiles_skill="/workspaces/.codespaces/.persistedshare/dotfiles/.claude/skills/personal-overrides"
    local link="$skills_dir/personal-overrides"

    if [ ! -L "$link" ]; then
        ln -s "$dotfiles_skill" "$link"
        echo "Claude skill symlink: created $link -> $dotfiles_skill"
    else
        echo "Claude skill symlink: already exists: $link"
    fi

    cp -f $DOTFILES_PATH/personal.py $WEB/src/aplaceforrover/rover/settings/personal.py
    echo "copied personal.py to $WEB/src/aplaceforrover/rover/settings/personal.py"
}